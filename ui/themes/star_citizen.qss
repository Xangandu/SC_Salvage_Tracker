    letter-spacing: 0.5px;
}

QLabel#versionLabel {
    color: #4D6B78;

    font-family: "Rajdhani";

    font-size: 11px;

    font-weight: bold;

    padding: 2px 12px 0 12px;
}

QLabel#versionLabel a {
    color: #E07A2A;

    text-decoration: none;
}

QWidget#navVersionDividerHost {
    background: transparent;
}

QSvgWidget#navVersionDivider {
    background: transparent;
    min-height: 22px;
