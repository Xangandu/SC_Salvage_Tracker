    font-weight: bold;
    letter-spacing: 2px;
}

QLabel#cardValue {
    color: #FFFFFF;

    font-family: "Rajdhani";

    font-size: 26px;

    font-weight: bold;
}

QLabel#statLabel {
    color: #8FA3B8;
    font-family: "Rajdhani";
    font-size: 16px;
    font-weight: 600;
}

QLabel#statValue {
    color: #FFFFFF;

    font-family: "Rajdhani";

    font-size: 18px;

    font-weight: bold;
}

QLabel#profitLabel {
    color: #F0A848;
    font-family: "Orbitron";

    font-size: 22px;

    font-weight: bold;
}

QLabel#formLabel {
    color: #E07A2A;
    font-family: "Rajdhani";
    font-size: 14px;
    font-weight: bold;
