}


/* ==========================================================
   21. DASHBOARD
   ========================================================== */

QLabel#dashboardSection {
    color: #F2F7FB;
    font-family: "Orbitron";
    font-size: 14px;
    font-weight: bold;
    letter-spacing: 3px;
    padding-top: 6px;
    padding-bottom: 8px;
}

QScrollArea#dashboardScroll {
    background: transparent;
    border: none;
}

QScrollArea#dashboardScroll > QWidget {
    background: transparent;
}

QWidget#dashboardScrollViewport {
    background: transparent;
}

QWidget#dashboardPage {
    background: transparent;
}

QWidget#dashboardContent {
    background: transparent;
}

QWidget#dashboardOperationsPanel {
    background: transparent;
}

QFrame#dashboardAlertStrip {
    background: rgba(23, 30, 40, 0.85);
    border: 1px solid #33485C;
    border-radius: 6px;
}

QFrame#dashboardAlertStrip QLabel#warningBannerTitle {
    font-size: 14px;
    font-weight: 600;
}

QToolButton#dashboardAlertBell {
    background: transparent;
    border: 1px solid #33485C;
    border-radius: 6px;
    padding: 4px;
}

QToolButton#dashboardAlertBell:hover {
    border-color: #E07A2A;
    background: rgba(224, 122, 42, 0.12);
}

QToolButton#dashboardAlertBell:checked {
    border-color: #E07A2A;
    background: rgba(224, 122, 42, 0.2);
}

QToolButton#dashboardAlertBell:disabled {
    opacity: 0.35;
}

QLabel#dashboardContextTitle {
    color: #F2F7FB;
    font-family: "Orbitron";
    font-size: 38px;
    font-weight: bold;
    letter-spacing: 4px;
    padding-bottom: 4px;
}

QLabel#dashboardContextHelp {
    color: #9FB4C8;
    font-family: "Rajdhani";
    font-size: 15px;
    font-weight: 600;
    line-height: 1.35;
    padding: 8px 12px;
    background: rgba(23, 30, 40, 0.65);
    border: 1px solid #263545;
    border-radius: 6px;
}

QLabel#dashboardTimelineWhen {
    color: #9FB4C8;
    font-family: "Rajdhani";
    font-size: 12px;
    font-weight: 600;
}

QWidget#dashboardTimelineRow QLabel#formLabel {
    font-size: 12px;
    padding-top: 0;
    letter-spacing: 0.5px;
}

QWidget#dashboardTimelineRow QLabel#mutedLabel {
    font-size: 12px;
    font-weight: 500;
}

QFrame#dashboardCard QLabel#cardValue {
    color: #FFFFFF;
    font-family: "Rajdhani";
    font-size: 22px;
    font-weight: bold;
    padding: 4px 0 8px 0;
    min-height: 28px;
}

QFrame#dashboardCard QLabel#dashboardFieldValue {
    color: #FFFFFF;
    font-family: "Rajdhani";
    font-size: 24px;
    font-weight: bold;
    padding: 6px 0 10px 0;
    min-height: 32px;
}

QFrame#dashboardCard {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    border: 1px solid #263545;
    border-radius: 8px;
    padding: 18px;
    min-height: 120px;
}

QFrame#hudLine {
    background: #33485C;
    color: #33485C;
    max-height: 1px;
    border: none;
}

QFrame#hudLineVertical {
    background: #33485C;
    color: #33485C;
    max-width: 1px;
    min-width: 1px;
    border: none;
}

QLabel#hudMarker {
    color: #E07A2A;
    font-size: 16px;
    font-weight: bold;
}

QSplitter#pageSplit {
    background: transparent;
}

QSplitter#pageSplit::handle:horizontal {
    width: 14px;
    margin: 16px 0;
    background: qlineargradient(
        x1: 0, y1: 0, x2: 1, y2: 0,
        stop: 0 transparent,
        stop: 0.40 transparent,
        stop: 0.44 #263545,
        stop: 0.48 #33485C,
        stop: 0.50 #E07A2A,
        stop: 0.52 #33485C,
        stop: 0.56 #263545,
        stop: 0.60 transparent,
        stop: 1 transparent
    );
}

QSplitter#pageSplit::handle:horizontal:hover {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 1, y2: 0,
        stop: 0 transparent,
        stop: 0.40 transparent,
        stop: 0.44 #33485C,
        stop: 0.48 #4A6278,
        stop: 0.50 #F09040,
        stop: 0.52 #4A6278,
        stop: 0.56 #33485C,
        stop: 0.60 transparent,
        stop: 1 transparent
    );
}

QMainWindow#dashboardWindow {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #0A0D12,
        stop: 0.45 #101620,
        stop: 1 #07090D
    );
}

QWidget#dashboardWindowCentral {
    background: transparent;
}


/* ==========================================================
   22. DATA TABLES
   ========================================================== */

QTableWidget#dataTable,
QTableWidget#historyTable {
    background-color: #0E141C;
    color: #D8E4EF;
    border: 1px solid #263545;
    border-radius: 8px;
    gridline-color: #1E2A38;
    selection-background-color: #1A3348;
    selection-color: #F4F8FC;
    alternate-background-color: #121820;
    outline: none;
}

QTableWidget#dataTable::item,
QTableWidget#historyTable::item {
    padding: 8px 10px;
    background-color: transparent;
    border: none;
}

QTableWidget#dataTable::item:alternate,
QTableWidget#historyTable::item:alternate {
    background-color: #121820;
}

QTableWidget#dataTable::item:selected,
QTableWidget#historyTable::item:selected {
    background-color: #1A3348;
    color: #F4F8FC;
}

QTableWidget#dataTable QHeaderView,
QTableWidget#historyTable QHeaderView,
QTableWidget#editableTable QHeaderView {
    background-color: #141C26;
    border: none;
    border-bottom: 1px solid #263545;
}

QTableWidget#dataTable QHeaderView::section,
QTableWidget#historyTable QHeaderView::section,
QTableWidget#editableTable QHeaderView::section {
    background-color: #141C26;
    color: #8FA3B8;
    border: none;
    border-bottom: 1px solid #263545;
    border-right: 1px solid #1A2430;
    padding: 10px 12px;
    font-family: "Orbitron";
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
}

QTableWidget#dataTable QHeaderView::section:last,
QTableWidget#historyTable QHeaderView::section:last,
QTableWidget#editableTable QHeaderView::section:last {

    border-right: none;
}

QTableWidget#dataTable QTableCornerButton::section,
QTableWidget#historyTable QTableCornerButton::section,
QTableWidget#editableTable QTableCornerButton::section {
    background-color: #141C26;
    border: none;
    border-bottom: 1px solid #263545;
}

QTableWidget#dataTable QScrollBar:vertical,
QTableWidget#historyTable QScrollBar:vertical,
QTableWidget#editableTable QScrollBar:vertical,
QTableWidget#dataTable QScrollBar:horizontal,
QTableWidget#historyTable QScrollBar:horizontal,
QTableWidget#editableTable QScrollBar:horizontal {
    background: #0C1016;
    border: none;
}

QTableWidget#dataTable QScrollBar::handle:vertical,
QTableWidget#historyTable QScrollBar::handle:vertical,
QTableWidget#editableTable QScrollBar::handle:vertical,
QTableWidget#dataTable QScrollBar::handle:horizontal,
QTableWidget#historyTable QScrollBar::handle:horizontal,
QTableWidget#editableTable QScrollBar::handle:horizontal {
    background: #2A3848;
    border-radius: 4px;
    min-height: 20px;
    min-width: 20px;
}


/* ==========================================================
   23. CHANGELOG & READ-ONLY VIEWS
   ========================================================== */

QTextEdit#changelogView,
QTextEdit#readOnlyPanel {
    background-color: #0E141C;
    color: #D8E4EF;
    border: 1px solid #263545;
    border-radius: 8px;
    padding: 14px;
    font-family: "Rajdhani";
    font-size: 14px;
    font-weight: 600;
}


/* ==========================================================
   23b. AAA TAB SYSTEM (Einstellungen, Changelog, global)
   ========================================================== */

QTabWidget {
    background: transparent;
}

QTabWidget::pane {
    border: 1px solid #33485C;
    border-top: 1px solid #33485C;
    border-radius: 0 0 8px 8px;
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    top: 0;
    padding: 4px;
}

QTabWidget::tab-bar {
    alignment: left;
}

QTabWidget QTabBar::tab {
    background: #0D1218;
    color: #7C92A8;
    border: 1px solid #243040;
    border-bottom: 1px solid #243040;
    border-top: 2px solid transparent;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 12px 28px 10px 28px;
    margin-right: 3px;
    margin-top: 4px;
    font-family: "Orbitron";
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 2px;
    min-width: 72px;
}

QTabWidget QTabBar::tab:selected {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #1B2430,
        stop: 1 #141C26
    );
    color: #F4F8FC;
    border-color: #33485C;
    border-bottom: 1px solid #141C26;
    border-top: 2px solid #E07A2A;
    margin-top: 0;
    padding-top: 14px;
}

QTabWidget QTabBar::tab:hover:!selected {
    background: #151D27;
    color: #C5D6E6;
    border-color: #3A5168;
}

QTabWidget QTabBar::tab:selected:hover {
    border-top: 2px solid #F09848;
}

QTabWidget#changelogTabs,
QTabWidget#settingsTabs,
QTabWidget#designSubTabs {
    background: transparent;
}

QTabWidget#designSubTabs::pane {
    border: 1px solid #263545;
    border-top: 1px solid #263545;
    border-radius: 0 0 8px 8px;
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    top: -1px;
    padding: 0;
    margin: 0;
}

QTabWidget#designSubTabs QTabBar::tab {
    min-width: 128px;
    min-height: 34px;
    padding: 10px 18px 9px 18px;
    margin-top: 0;
    margin-bottom: -1px;
    margin-right: 2px;
    border-bottom: 1px solid #243040;
}

QTabWidget#designSubTabs QTabBar::tab:selected {
    background: #171E28;
    border-color: #263545;
    border-bottom: 1px solid #171E28;
    margin-top: 0;
    margin-bottom: -1px;
    padding-bottom: 10px;
}

QTabWidget#designSubTabs QTabBar::tab:hover:!selected {
    margin-bottom: -1px;
}

QWidget#designSubPage {
    background: transparent;
    min-height: 420px;
}

QWidget#designSubPage QFrame#pagePanel {
    background: transparent;
    border: none;
    border-radius: 0;
}

QFrame#designColorControl {
    background: transparent;
    border: none;
}

QPushButton#designColorSwatch {
    background-color: #141C26;
    border: 1px solid #33485C;
    border-radius: 8px;
    padding: 0;
}

QWidget#settingsTabContent {
    background: transparent;
}


/* ==========================================================
   24. INPUT DIALOGS
   ========================================================== */

QInputDialog {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #1B2A38,
        stop: 0.35 #121E29,
        stop: 1 #030608
    );
}

QInputDialog QLabel {
    color: #D9F4FF;
}


/* ==========================================================
   25. PAGE CONTENT PANELS
   ========================================================== */

QFrame#pagePanel {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    border: 1px solid #263545;
    border-radius: 8px;
    padding: 20px;
}

QFrame#loginCard {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #10161E
    );
    border: 1px solid #2A3848;
    border-radius: 10px;
}

QLabel#loginLogo {
    color: #F2F7FB;
    font-family: "Orbitron";
    font-size: 26px;
    font-weight: bold;
    letter-spacing: 6px;
}

QLabel#loginTagline {
    color: #6F8599;
    font-size: 12px;
    letter-spacing: 3px;
}

QLabel#setupStepIndicator {
    color: #E07A2A;
    font-family: "Orbitron";
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 2px 0 6px 0;
}

QStackedWidget#setupWizardStack {
    background: transparent;
    border: none;
    min-height: 280px;
}

QDialog#mobiglasDialog QStackedWidget#setupWizardStack QLineEdit {
    min-height: 34px;
}

QLabel#setupVersionFooter {
    color: #4A6070;
    font-family: "Rajdhani";
    font-size: 12px;
    letter-spacing: 1px;
}

QLabel#setupSuccessLabel {
    color: #42D4F5;
    font-family: "Orbitron";
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 8px 0 4px 0;
}

QFrame#navDivider {
    background: #1E2A38;
    border: none;
    min-height: 1px;
    max-height: 1px;
    margin: 0 16px;
}

QFrame#pagePanel QLabel#statLabel {
    margin-top: 6px;
}


/* ==========================================================
   26. STATISTICS PLACEHOLDER
   ========================================================== */

QLabel#placeholderLabel {
    color: #4D6B78;

    font-family: "Rajdhani";

    font-size: 18px;

    font-weight: bold;

    font-style: italic;

    padding: 40px;
}


/* ==========================================================
   27. START SPLASH
   ========================================================== */

#splashScreen {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #1B2A38,
        stop: 1 #030608
    );
}

QFrame#splashHudLine {
    color: #E07A2A;
    background-color: #E07A2A;
    max-height: 2px;
}

QLabel#splashHudMarker {
    color: #E07A2A;
    font-family: "Rajdhani";
    font-size: 16px;
    font-weight: bold;
    padding: 0 2px;
}

QLabel#splashStatus {
    color: #42D4F5;
    font-family: "Rajdhani";
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
}

QLabel#splashFooter {
    color: #4D6B78;

    font-family: "Rajdhani";

    font-size: 11px;

    font-weight: bold;

    letter-spacing: 0.5px;
}

QLabel#splashVersion {
    color: #C9A227;

    background: transparent;

    background-color: transparent;

    font-family: "Rajdhani";

    font-size: 11px;

    font-weight: bold;

    padding: 2px 6px;
}

QLabel#splashDeveloper {
    color: #C9A227;

    background: transparent;

    background-color: transparent;

    font-family: "Rajdhani";

    font-size: 11px;

    font-weight: bold;

    letter-spacing: 0.4px;

    padding: 0;
}

QFrame#splashProgressPanel {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 rgba(23, 30, 40, 238),
        stop: 1 rgba(14, 20, 28, 248)
    );
    border: 1px solid #263545;
    border-top: 2px solid #E07A2A;
    border-radius: 6px;
}

QLabel#splashPercent {
    color: #C9A227;
    font-family: "Rajdhani";
    font-size: 14px;
    font-weight: bold;
    letter-spacing: 0.6px;
    background: transparent;
}

QWidget#trackerLoadingBar {
    background: transparent;
}

/* ==========================================================
   28. MODULARES DASHBOARD (kompakt / filigran)
   ========================================================== */

QWidget#dashboardGridCanvas {
    background: transparent;
}

QWidget#dashboardGridHost {
    background: transparent;
}

QFrame#dashboardPlacedWidget {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
}

QFrame#dashboardKpiCard,
QFrame#dashboardSessionPanel {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    border: 1px solid #263545;
    border-radius: 8px;
    min-height: 0;
    min-width: 0;
    padding: 16px 18px;
}

QFrame#dashboardMaterialKpiCard {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    border: 1px solid #263545;
    border-radius: 8px;
    min-width: 0;
    max-width: 9999px;
    padding: 0;
}

QFrame#dashboardMaterialKpiPlaceholder {
    background: transparent;
    border: none;
    min-width: 0;
    padding: 0;
}

QFrame#dashboardMaterialKpiCard QLabel#cardTitle {
    padding: 0;
    margin: 0;
}

QLabel#dashboardMaterialGroupTitle {
    color: #8FA3B8;
    font-family: "Rajdhani";
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 0;
    margin: 0;
}

QFrame#dashboardMaterialKpiCard QLabel#subSectionTitle {
    padding: 0;
    margin: 0;
}

QFrame#dashboardMaterialKpiCard QLabel#cardValue {
    padding: 0;
    margin: 0;
}

QFrame#dashboardKpiCard QLabel#subSectionTitle,
QFrame#dashboardSessionPanel QLabel#subSectionTitle {
    padding: 0;
    margin: 0;
}

QFrame#dashboardSessionPanel QLabel#formLabel {
    padding-top: 0;
    margin: 0;
}

QFrame#dashboardSessionPanel QLabel#displayValue {
    padding: 0 0 2px 0;
    margin: 0;
}

QFrame#dashboardSessionPanel QLabel#mutedLabel {
    padding: 0 0 2px 0;
    margin: 0;
}

QFrame#dashboardSessionPanel QLabel#cardTitle {
    margin-top: 2px;
    padding: 0;
}

QFrame#dashboardKpiCard QLabel#cardValue,
QFrame#dashboardKpiCard QLabel#profitLabel {
    padding: 0;
    margin: 0;
}

QLabel#dashboardKpiDigit,
QWidget#dashboardKpiCard QLabel#dashboardKpiDigit {
    color: #FFFFFF;
    font-family: "Rajdhani";
    font-size: 26px;
    font-weight: bold;
    padding: 0;
    margin: 0;
    min-width: 0.55em;
}

QLabel#dashboardKpiDigitAccent,
QWidget#dashboardKpiCard QLabel#profitLabel > QLabel#dashboardKpiDigitAccent,
QWidget#dashboardKpiCard QLabel#dashboardKpiDigitAccent {
    color: #C9A227;
    font-family: "Rajdhani";
    font-size: 26px;
    font-weight: bold;
    padding: 0;
    margin: 0;
    min-width: 0.55em;
}

QWidget#dashboardCatalogPanel {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #171E28,
        stop: 1 #121820
    );
    border-left: 1px solid #263545;
}

QLabel#dashboardCatalogTitle {
    color: #93A8BC;
    font-family: "Orbitron";
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 0;
    margin: 0;
}

QLabel#dashboardCatalogHint {
    color: #6F8599;
    font-family: "Rajdhani";
    font-size: 11px;
    font-weight: bold;
    line-height: 1.3;
    padding: 0 2px;
    margin: 0;
}

QWidget#dashboardCatalogPanel QFrame#hudLine {
    background: #33485C;
    min-height: 1px;
    max-height: 1px;
    border: none;
}

QWidget#dashboardCatalogPanel QLabel#hudMarker {
    color: #E07A2A;
    font-size: 10px;
}

QFrame#dashboardCatalogDrop {
    background-color: rgba(38, 53, 69, 0.35);
    border: 1px dashed #33485C;
    border-radius: 8px;
    min-height: 44px;
}

QFrame#dashboardCatalogDrop[dragActive="true"] {
    background-color: rgba(224, 122, 42, 0.12);
    border: 1px solid #E07A2A;
}

QLabel#dashboardCatalogDropLabel {
    color: #93A8BC;
    font-family: "Rajdhani";
    font-size: 10px;
    font-weight: bold;
    font-style: italic;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
}

QFrame#dashboardCatalogItem {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #1A2430,
        stop: 1 #121820
    );
    border: 1px solid #263545;
    border-radius: 6px;
    min-height: 36px;
}

QFrame#dashboardCatalogItem:hover {
    border: 1px solid #E07A2A;
    background: qlineargradient(
        x1: 0, y1: 0, x2: 0, y2: 1,
        stop: 0 #1E2A38,
        stop: 1 #151D28
    );
}

QFrame#dashboardCatalogItem:disabled {
    background-color: #121820;
    border: 1px solid #1E2A38;
}

QLabel#dashboardCatalogLabel {
    color: rgba(217, 244, 255, 0.92);
    font-family: "Rajdhani";
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 0.8px;
    padding: 0;
    margin: 0;
}

QFrame#dashboardCatalogItem:disabled QLabel#dashboardCatalogLabel {
    color: rgba(217, 244, 255, 0.32);
}

QWidget#dashboardCatalogList {
    background: transparent;
}

QPushButton#dashboardWidgetRemove {
    background-color: #1E2A38;
    color: #FFFFFF;
    border: 1px solid #33485C;
    border-radius: 9px;
    min-width: 18px;
    max-width: 18px;
    min-height: 18px;
    max-height: 18px;
    font-family: "Segoe UI";
    font-size: 11px;
    font-weight: bold;
    padding: 0;
    padding-bottom: 1px;
}

QPushButton#dashboardWidgetRemove:hover {
    background-color: #E07A2A;
    color: #FFFFFF;
    border: 1px solid #E07A2A;
}

QWidget#dashboardHeader {
    background: transparent;
}

QScrollArea#dashboardCatalogScroll {
    background: transparent;
    border: none;
}

QScrollArea#dashboardCatalogScroll > QWidget {
    background: transparent;
}

QWidget#dashboardCatalogScrollViewport {
    background: transparent;
}