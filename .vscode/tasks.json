{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run SC Salvage Tracker",
      "type": "shell",
      "command": "py",
      "args": ["-3", "main.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
